# Copie este arquivo para `.env` na raiz do projeto e ajuste os valores.
# Nunca faça commit do arquivo `.env` real (já está no .gitignore).

# --- Postgres ---
# POSTGRES_USER é o dono do banco (superusuário) usado só pelas migrações
# (Alembic) -- veja core/config.py. A aplicação em si nunca conecta com este
# usuário: superusuário do Postgres ignora Row-Level Security completamente,
# então usar este usuário no dia a dia tornaria o RLS decorativo.
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Papel restrito (sem superusuário, sem bypass de RLS) que a aplicação e o
# worker realmente usam. Criado pela migração 0001 com esta senha.
APP_RUNTIME_DB_PASSWORD=app_runtime

# --- Backend ---
ENVIRONMENT=development
DEBUG=true

# Gere um valor aleatório forte antes de qualquer deploy real, ex: `openssl rand -hex 32`
JWT_SECRET_KEY=change-me-in-.env-this-is-a-placeholder-not-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=["http://localhost:8080","http://localhost:5173"]

# URL pública (voltada ao navegador, não à API) onde o frontend é servido --
# usada para montar links enviados por email/WhatsApp (ex: redefinição de
# senha). Em produção, aponte para o domínio real por trás do Cloudflare/nginx.
PUBLIC_APP_URL=http://localhost:8080

# --- Provedores plugáveis: console/mock funcionam sem nenhuma credencial externa ---
NOTIFICATION_PROVIDER=console
PAYMENT_PROVIDER=mock
EMAIL_PROVIDER=console

# Criptografa a senha SMTP de cada empresa (Company.smtp_password_encrypted)
# para poder recuperá-la depois e autenticar no servidor de email dela --
# diferente de todo outro segredo deste app (refresh tokens, senha de
# usuário), que é guardado só como hash de mão única. OBRIGATÓRIO gerar uma
# chave real (o valor padrão no código é deliberadamente inválido -- ao
# contrário do JWT_SECRET_KEY, um padrão "funcional" aqui significaria que
# qualquer um lendo este repositório público poderia decifrar a senha SMTP
# de qualquer empresa que esquecesse de configurar a própria chave):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Perder ou trocar esta chave sem migrar (re-criptografar) torna toda senha
# SMTP já salva permanentemente ilegível -- cada empresa precisaria reconectar.
SMTP_CREDENTIALS_ENCRYPTION_KEY=

# A cada quantos minutos o serviço `scheduler` verifica agendamentos
# precisando de lembrete 24h/2h antes.
REMINDER_SCAN_INTERVAL_MINUTES=5

# --- Mercado Pago (sandbox) — preencha quando for testar pagamento de verdade ---
# Obtenha em https://www.mercadopago.com.br/developers (conta de teste/sandbox)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- WhatsApp (fica stub até haver conta aprovada) ---
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# Escolhido por você ao registrar o webhook no Meta Business App (qualquer
# valor secreto seu) -- Meta ecoa esse valor de volta no handshake de
# verificação (GET) para confirmar que você é o dono da URL.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-in-.env
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
